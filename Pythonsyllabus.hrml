<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PyLearn | Python Programming</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="pystyle.css">

</head>

<body>

<header>
  <h2>PyLearn</h2>

  <nav>
    <a href="#" onclick="loadPage('home.html')">Home</a>
    <a href="#" onclick="loadPage('course.html')">Courses</a>

    <div class="profile" id="profileMenu">
      <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png">

      <div class="profile-menu">
        <a href="#" onclick="loadPage('profile.html')">My Profile</a>
        <a href="#" onclick="loadPage('dashboard.html')">Dashboard</a>
        <button onclick="logout()">Logout</button>
      </div>
    </div>

  </nav>
</header>

<div class="container">

  <div class="course-title">Python Programming</div>

  <div class="topic" onclick="loadPage('PythonIntro.html')">
    <span>Introduction to Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonControlFlowIntro.html')">
    <span>Control Flow Constructs in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonFunctionsIntro.html')">
    <span>Functions and Modules in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonArraysStrings.html')">
    <span>Arrays and Strings in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonListsIntro.html')">
    <span>Lists in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonDataStructures.html')">
    <span>Tuples, Sets, Dictionaries in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonOOP.html')">
    <span>Object Oriented Programming in Python</span>
    <button>View</button>
  </div>

  <div class="topic" onclick="loadPage('PythonFileIntro.html')">
    <span>File Handling and Exception Handling in Python</span>
    <button>View</button>
  </div>

</div>

<script src="pyapp.js"></script>

</body>
</html>
